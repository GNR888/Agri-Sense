# Copy to .env and fill in values

# Data directories (defaults shown; override if needed)
AGRI_SENSE_DATA_DIR=data

# NASA POWER API (no key needed for MVP — public endpoint)
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# SoilGrids 2.0 (no key needed — public endpoint)
SOILGRIDS_BASE_URL=https://rest.isric.org/soilgrids/v2.0

# Microsoft Planetary Computer (anonymous access for MVP)
PC_SDK_SUBSCRIPTION_KEY=

# Future: GSO yield data credentials
GSO_API_KEY=
