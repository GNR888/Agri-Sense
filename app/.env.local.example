# Copy to .env.local and fill in values before running locally.
# In Vercel: add NEXT_PUBLIC_API_URL as an environment variable in Project Settings → Environment Variables.

# URL of the deployed FastAPI backend.
# For local development the backend runs on port 8000 (default).
# For production, point this to your deployed backend (Railway, Render, Fly.io, etc.)
NEXT_PUBLIC_API_URL=http://localhost:8000
